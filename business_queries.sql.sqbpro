-- PROJECT: EXECUTIVE WORKFORCE ANALYTICS &amp; COMPENSATION OPTIMIZATION
-- LAYER: BACKEND ANALYTICAL QUERY SUITE
-- FILE: business_queries.sql
-- ====================================================================

-- Query 1: Internal Compensation Ranking Analysis
-- Business Purpose: Identifies salary distribution hierarchies within departments to flag potential compression metrics.
SELECT 
    CleanDepartment AS Department,
    EmployeeName AS Employee,
    CurrentSalary AS Salary,
    RANK() OVER(PARTITION BY CleanDepartment ORDER BY CurrentSalary DESC) AS Salary_Rank
FROM employees;


-- Query 2: Financial Attrition Exposure Matrix
-- Business Purpose: Quantifies total annual salary capital tied up in high/medium attrition risk tiers per business unit.
SELECT 
    CleanDepartment AS Department,
    LeavingRisk AS Risk_Level,
    COUNT(EmployeeID) AS Total_Employees,
    SUM(CurrentSalary) AS Financial_Risk_Exposure
FROM employees
GROUP BY CleanDepartment, LeavingRisk
ORDER BY Financial_Risk_Exposure DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
